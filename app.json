{
  "expo": {
    "name": "MyanmarQuizApp",
    "slug": "MyanmarQuizApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mmquiz.jpg",
    "scheme": "myanmarquizapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/mmquiz.jpg",
        "backgroundImage": "./assets/images/mmquiz.jpg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.amarakyaw.MyanmarQuizApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/mmquiz.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mmquiz.jpg",
          "imageWidth": 300,
          "imageHeight": 300,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd7f6fa2-4d6b-43fc-87cf-bd6d66c17ee9"
      }
    }
  }
}
